<%@ Page Title="" Language="C#" MasterPageFile="~/Site.Master" AutoEventWireup="true" CodeBehind="DataScience.aspx.cs" Inherits="Aptum.DataScience" %>
<asp:Content ID="Content1" ContentPlaceHolderID="head" runat="server">
</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="ContentPlaceHolder1" runat="server">
    <!-- HERO -->
<section class="relative py-32 px-6 md:px-20 text-white overflow-hidden">

    <!-- Background Image -->
    <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71"
             class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-[#0b0f19]/85"></div>
    </div>

    <!-- Content -->
    <div class="relative max-w-5xl mx-auto text-center">

        <h1 class="text-5xl md:text-6xl font-semibold leading-tight mb-6">
            Turn Data into Decisions <br />
            <span class="bg-gradient-to-r from-orange-400 to-pink-500 bg-clip-text text-transparent">
                That Drive Real Business Growth
            </span>
        </h1>

        <p class="text-gray-300 text-lg max-w-3xl mx-auto mb-10 leading-relaxed">
            Every business generates data — but very few truly understand it. Data Science 
            bridges that gap by transforming raw data into meaningful insights, predictions, 
            and intelligent decisions. It’s not just about numbers — it’s about clarity, strategy, 
            and competitive advantage.
        </p>

        <div class="flex justify-center gap-4">
            <a href="#" class="bg-white text-black px-6 py-3 rounded-full font-medium hover:scale-105 transition">
                Explore Solutions
            </a>

            <a href="#" class="border border-gray-400 px-6 py-3 rounded-full hover:bg-white hover:text-black transition">
                Talk to Expert
            </a>
        </div>

    </div>

</section>


<!-- DEEP INTRO -->
<section class="py-24 px-6 md:px-20 bg-[#0b0f19] text-white">

    <div class="max-w-6xl mx-auto text-center">

        <h2 class="text-4xl font-semibold mb-10">
            What Data Science Really Means for Your Business
        </h2>

        <div class="space-y-6 text-gray-400 leading-relaxed max-w-4xl mx-auto">

            <p>
                Data Science is often misunderstood as just analytics or dashboards. In reality, 
                it goes much deeper. It’s about uncovering patterns, predicting future outcomes, 
                and enabling smarter decision-making at every level of an organization.
            </p>

            <p>
                Whether it’s understanding customer behavior, optimizing operations, detecting 
                risks, or forecasting demand — data science provides the intelligence needed to 
                move from guesswork to confidence.
            </p>

            <p>
                In a competitive market, companies that use data effectively don’t just survive — 
                they lead. Data becomes their strongest asset.
            </p>

        </div>

    </div>

</section>


<!-- VALUE SECTION -->
<section class="py-24 px-6 md:px-20 bg-[#05070f] text-white">

    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">

        <div>
            <h2 class="text-3xl font-semibold mb-6">
                From Raw Data to Actionable Insights
            </h2>

            <p class="text-gray-400 mb-4 leading-relaxed">
                Most organizations already have data — but it’s scattered, unstructured, 
                and underutilized. Data Science helps organize, clean, and transform this data 
                into something meaningful.
            </p>

            <p class="text-gray-400 mb-4 leading-relaxed">
                By applying statistical models, machine learning algorithms, and visualization 
                techniques, we convert raw information into insights that can guide real business decisions.
            </p>

            <p class="text-gray-400 leading-relaxed">
                The result is not just reports — but clarity, direction, and measurable outcomes.
            </p>
        </div>

        <div class="space-y-6">
            <div class="p-6 bg-[#111827] rounded-xl border border-gray-800">
                📊 Data Analysis & Visualization
            </div>
            <div class="p-6 bg-[#111827] rounded-xl border border-gray-800">
                🤖 Machine Learning Models
            </div>
            <div class="p-6 bg-[#111827] rounded-xl border border-gray-800">
                🔮 Predictive Analytics
            </div>
        </div>

    </div>

</section>


<!-- FEATURES -->
<section class="py-24 px-6 md:px-20 bg-[#0b0f19] text-white">

    <h2 class="text-4xl font-semibold text-center mb-16">
        What You Can Achieve with Data Science
    </h2>

    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-10">

        <div>
            <h3 class="text-lg font-semibold mb-3">Customer Insights</h3>
            <p class="text-gray-400 leading-relaxed">
                Understand customer behavior, preferences, and patterns to deliver personalized experiences.
            </p>
        </div>

        <div>
            <h3 class="text-lg font-semibold mb-3">Operational Efficiency</h3>
            <p class="text-gray-400 leading-relaxed">
                Identify inefficiencies and optimize processes using data-driven strategies.
            </p>
        </div>

        <div>
            <h3 class="text-lg font-semibold mb-3">Predictive Decision-Making</h3>
            <p class="text-gray-400 leading-relaxed">
                Forecast trends and outcomes to make proactive, informed decisions.
            </p>
        </div>

    </div>

</section>


<!-- PROCESS -->
<section class="py-24 px-6 md:px-20 bg-[#05070f] text-white">

    <h2 class="text-4xl font-semibold text-center mb-16">
        Our Data Science Approach
    </h2>

    <div class="max-w-5xl mx-auto space-y-6 text-gray-400">

        <p>
            We begin by understanding your business objectives — because data without context 
            has no value. Our goal is to align every model and analysis with real business outcomes.
        </p>

        <p>
            Next, we collect and prepare data, ensuring it is clean, structured, and ready for analysis. 
            This step is crucial because the quality of insights depends entirely on the quality of data.
        </p>

        <p>
            We then apply advanced analytics and machine learning models to uncover patterns and generate predictions.
        </p>

        <p>
            Finally, we present insights in a clear, visual format so decision-makers can act with confidence.
        </p>

    </div>

</section>


<!-- CTA -->
<section class="py-28 text-center px-6 bg-gradient-to-r from-[#0b0f19] to-[#020617] text-white">

    <h2 class="text-4xl font-semibold mb-4">
        Make Smarter Decisions with Data
    </h2>

    <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        Data is powerful — but only if you know how to use it. Let’s turn your data into a competitive advantage.
    </p>

    <a href="#" class="bg-orange-500 hover:bg-orange-600 px-8 py-3 rounded-full transition">
        Get Started
    </a>

</section>

</asp:Content>
